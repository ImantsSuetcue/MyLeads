# Copy this file to ".env" in the /backend folder and fill in real values
# as you get them. Everything works with fake data until you do, thanks to MOCK_MODE.

# --- Server ---
PORT=3000
NODE_ENV=development
# Must be scheme+host+port only (no path) — the browser's Origin header never has one.
CORS_ORIGIN=http://127.0.0.1:5500
# Where Live Server actually serves index.html from — MAY include a path. If you
# open frontend/index.html with VS Code's Live Server, it serves from the project
# root, so the default below (with /frontend) is correct. Used to build the mock
# Stripe checkout link and (later) real Stripe success/cancel URLs.
FRONTEND_BASE_URL=http://127.0.0.1:5500/frontend
# Any long random string. Used to sign login tokens (JWT). Change this in production.
JWT_SECRET=change-me-to-a-long-random-string

# --- Database ---
DB_FILE_NAME=myleads.db

# --- Mock mode ---
# true  = Claude/Apollo/Stripe calls return realistic fake data (no keys needed).
# false = real API calls are made using the keys below.
MOCK_MODE=true

# --- Anthropic (Claude) ---
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Apollo.io ---
# Get a key at https://app.apollo.io -> Settings -> API
APOLLO_API_KEY=

# --- Stripe ---
# Get keys at https://dashboard.stripe.com/test/apikeys (use TEST keys while developing)
STRIPE_SECRET_KEY=
# Created after you run `stripe listen` locally, or from the Stripe Dashboard webhook settings
STRIPE_WEBHOOK_SECRET=
# Price IDs for the three plans (Stripe Dashboard -> Product catalog). Optional while MOCK_MODE=true.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_ENTERPRISE=

# --- Platform-Admin seed (used once by `npm run seed:admin`) ---
PLATFORM_ADMIN_EMAIL=admin@example.com
PLATFORM_ADMIN_PASSWORD=change-me

# --- Lead-Finder tuning ---
MAX_LEADS_PER_SEARCH=20

# --- Compliance scraper (DSGVO) ---
# Minimum wait, in milliseconds, between two requests to the same company domain.
SCRAPER_MIN_DELAY_MS=3000
